{
  "testEnvironment": "jsdom",
  "moduleNameMapper": {
    "\\.(css|less|scss)$": "identity-obj-proxy",
    "\\.(jpg|jpeg|png|gif|svg)$": "<rootDir>/__mocks__/fileMock.js"
  },
  "transform": {
    "^.+\\.[jt]sx?$": "babel-jest"
  },
  "testMatch": [
    "**/__tests__/**/*.{js,jsx}",
    "**/*.test.{js,jsx}"
  ]
}